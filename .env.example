# Terminal Server Configuration
# Copy this to .env and modify as needed

# Server Settings
HOST=0.0.0.0
PORT=5000
DEBUG=False

# Security
SECRET_KEY=your-super-secret-key-change-this-in-production

# CORS Settings (comma-separated origins)
CORS_ORIGINS=*

# Logging
LOG_LEVEL=INFO

# Shell
SHELL=/bin/bash
